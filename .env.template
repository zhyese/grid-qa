# ============================================================================
# 电网运维 RAG 智能问答系统 — 发行版配置模板
# ----------------------------------------------------------------------------
# 用法(Linux 接收方):
#   cp .env.template .env
#   # 填掉下方所有 <CHANGE_ME_> 开头的值（install.sh 会校验 3 个 API Key 必填）
#   ./install.sh up
#
# 说明:
#   - 本文件与 backend/app/config.py 的 Settings 字段一一对应，每项均有默认值。
#   - 仅 5 处 <CHANGE_ME> 必须自行填入；其余基础设施默认值已对齐 docker-compose.deploy.yml。
#   - ⚠️ provider 一致性：随包分发的向量库(grid_chunks)是按 qwen(text-embedding-v3, 1024维)
#     生成的。接收方 EMB_PROVIDER 必须用 qwen，否则检索失效需重建 collection。
#   - 网络：默认直连(空代理)。若服务器需走公司代理，取消下方 HTTP_PROXY/HTTPS_PROXY 注释填地址。
# ============================================================================

# ---------- 应用 ----------
APP_NAME=电网运维 RAG 智能问答系统
APP_VERSION=0.1.0
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8001
API_PREFIX=/api
DEBUG=false

# ---------- 网络（默认直连；需代理时取消注释并填地址）----------
# HTTP_PROXY=http://你的代理:端口
# HTTPS_PROXY=http://你的代理:端口
NO_PROXY=localhost,127.0.0.1,mysql,minio,milvus,redis,neo4j,prometheus,grafana

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=grid_qa
MYSQL_USER=grid
MYSQL_PASSWORD=grid123456
MYSQL_HOST=localhost
MYSQL_PORT=3307
# 容器内由 compose 覆盖为 mysql:3306；此处仅占位
DATABASE_URL=mysql+aiomysql://grid:grid123456@localhost:3307/grid_qa?charset=utf8mb4

# ---------- MinIO ----------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=grid-documents
MINIO_SECURE=false

# ---------- JWT ----------
JWT_SECRET=<CHANGE_ME_请改为64位以上随机字符串>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---------- 默认管理员（首次启动若库中无 admin 则用此创建；随包库已含 admin，此处仅兜底）----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<CHANGE_ME_管理员密码>

# ---------- 模型 Provider ----------
# LLM 可切换：deepseek | qwen | doubao
LLM_PROVIDER=deepseek
# Embedding：随包向量库为 qwen 生成，请勿改为 doubao（否则需重建 collection）
EMB_PROVIDER=qwen
EMBEDDING_DIM=1024

# --- DeepSeek ---
DEEPSEEK_API_KEY=<CHANGE_ME_deepseek_api_key>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- 阿里百炼 DashScope（OpenAI 兼容）---
DASHSCOPE_API_KEY=<CHANGE_ME_dashscope_api_key>
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_LLM_MODEL=qwen-plus
QWEN_EMB_MODEL=text-embedding-v3

# --- 火山方舟 Ark（OpenAI 兼容；model 字段传 endpoint_id）---
ARK_API_KEY=<CHANGE_ME_ark_api_key>
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_LLM_ENDPOINT_ID=<CHANGE_ME_doubao_endpoint_id>
DOUBAO_EMB_MODEL=doubao-embedding-text-240815

# ---------- Milvus（双 collection，向量空间隔离）----------
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=grid_chunks              # 云 embedding(1024维)向量库
MILVUS_COLLECTION_BGE=grid_chunks_bge      # 本地 bge(512维)向量库,独立 collection

# ---------- Redis（热点问答缓存 + 配置持久化 + query 向量缓存）----------
REDIS_URL=redis://localhost:6379/0
QA_CACHE_TTL=3600

# ---------- Neo4j（知识图谱：设备-故障-处置 多跳推理）----------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123456
KG_RAG_ENABLE=true

# ---------- 重排（rerank）----------
RERANK_ENABLE=true
RERANK_MODEL=gte-rerank-v2

# ---------- 检索质量 ----------
MMR_ENABLE=true
MMR_LAMBDA=0.6
QUERY_REWRITE_ENABLE=false
BGE_MODEL=BAAI/bge-small-zh-v1.5
BGE_DIM=512
DOC_SIZE_THRESHOLD=5000

# ---------- 分块 ----------
CHUNK_SIZE=500
CHUNK_OVERLAP=80

# ---------- Corrective RAG（检索自纠错闭环）----------
CRAG_ENABLE=true
CRAG_HIGH=0.6
CRAG_LOW=0.3
CRAG_PERDOC_ENABLE=false

# ---------- 结构感知分块 + Parent-Child ----------
SMALL_TO_BIG_ENABLE=true
PARENT_SIZE=2000
PARENT_OVERLAP=200

# ---------- 检索增强（默认关，按需开）----------
HYDE_ENABLE=false
MULTI_QUERY_ENABLE=false
SELF_RAG_ENABLE=false
STANDALONE_REWRITE_ENABLE=true

# ---------- 安全合规（电网强监管）----------
SAFETY_FILTER_ENABLE=true
PII_MASK_ENABLE=false
HIGH_RISK_KEYWORDS=停电,拉闸,合闸,接地,挂地线,带电,登高,攀登,放电,倒闸

# ---------- 实时事件接入 ----------
ALERT_WEBHOOK_TOKEN=
ALERT_WEBHOOK_TENANT=default
REALTIME_EVENT_CREDENTIAL_TENANT=default
REALTIME_EVENT_TOKEN=please-change-realtime-ingress-token
REALTIME_EVENT_SIGNING_SECRET=please-change-realtime-hmac-secret
REALTIME_EVENT_TENANT_TOKENS={}
REALTIME_EVENT_TENANT_SIGNING_SECRETS={}

# ---------- 可信度评测 ----------
ONLINE_FAITHFULNESS_ENABLE=true
FAITHFULNESS_GATE=0.85

# ---------- 多模态 RAG ----------
VLM_ENABLE=false
QWEN_VLM_MODEL=qwen-vl-max

# ---------- 配置中心 Nacos（默认 .env，不依赖）----------
CONFIG_SOURCE=env
NACOS_SERVER=http://localhost:8848
NACOS_NAMESPACE=
NACOS_GROUP=DEFAULT_GROUP
NACOS_DATA_ID=grid-qa.properties

# ---------- 检索参数调优 ----------
TUNE_ENABLE=true
TUNE_MIN_IMPROVE=0.02
TUNE_MIN_SAMPLE=10
TUNE_SCAN_TOPK=5
