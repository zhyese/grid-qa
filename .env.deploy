# ===== 远端部署 .env 模板 =====
# 部署步骤:
#   1. cp .env.deploy .env
#   2. 填入下方 <CHANGE_ME> 的真实值
#   3. docker compose -f docker-compose.deploy.yml up -d --build

# ---------- 应用 ----------
APP_NAME=电网运维 RAG 智能问答系统
APP_VERSION=0.1.0
API_PREFIX=/api
DEBUG=false

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=grid_qa
MYSQL_USER=grid
MYSQL_PASSWORD=grid123456
MYSQL_HOST=localhost
MYSQL_PORT=3307
# 容器内覆盖，此处仅占位
DATABASE_URL=mysql+aiomysql://grid:grid123456@localhost:3307/grid_qa?charset=utf8mb4

# ---------- MinIO ----------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=<CHANGE_ME_minio_secret>
MINIO_BUCKET=grid-documents
MINIO_SECURE=false

# ---------- JWT ----------
JWT_SECRET=<CHANGE_ME_generate_random_64_chars>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---------- 默认管理员 ----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<CHANGE_ME_admin_password>

# ---------- 模型 Provider ----------
LLM_PROVIDER=deepseek
EMB_PROVIDER=qwen
EMBEDDING_DIM=1024

# --- DeepSeek ---
DEEPSEEK_API_KEY=<CHANGE_ME_deepseek_api_key>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- 阿里百炼 DashScope ---
DASHSCOPE_API_KEY=<CHANGE_ME_dashscope_api_key>
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_LLM_MODEL=qwen-plus
QWEN_EMB_MODEL=text-embedding-v3

# --- 火山方舟 Ark ---
ARK_API_KEY=<CHANGE_ME_ark_api_key>
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_LLM_ENDPOINT_ID=<CHANGE_ME_doubao_endpoint_id>
DOUBAO_EMB_MODEL=doubao-embedding-text-240815

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0
QA_CACHE_TTL=259200
CACHE_PERSIST_ENABLE=true
CACHE_TIERED_TTL_ENABLE=true

# ---------- Milvus ----------
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=grid_chunks

# ---------- 分块 ----------
CHUNK_SIZE=500
CHUNK_OVERLAP=80
