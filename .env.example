# ===== 复制为 .env 并填入真实值；.env 不会提交到仓库 =====
# 本文件与 backend/app/config.py 的 Settings 字段一一对应（每项均有默认值，开发可直接用）。
# 仅三家属地的 API Key 必须自行填入，其余基础设施默认值已对齐 docker-compose。

# ---------- 应用 ----------
APP_NAME=电网运维 RAG 智能问答系统
APP_VERSION=0.1.0
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8001
API_PREFIX=/api
DEBUG=true

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=grid_qa
MYSQL_USER=grid
MYSQL_PASSWORD=grid123456
MYSQL_HOST=localhost
MYSQL_PORT=3307
# 后端连接串（aiomysql 异步驱动；宿主机映射 3307，避开本机已装的 MySQL）
DATABASE_URL=mysql+aiomysql://grid:grid123456@localhost:3307/grid_qa?charset=utf8mb4

# ---------- MinIO ----------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=grid-documents
MINIO_SECURE=false

# ---------- JWT ----------
JWT_SECRET=please-change-this-to-a-random-long-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---------- 默认管理员（首次启动自动创建）----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ---------- 模型 Provider（云 API）----------
# LLM 可切换：deepseek | qwen | doubao
LLM_PROVIDER=deepseek
# Embedding 可切换：qwen | doubao （DeepSeek 无 embedding 接口）
EMB_PROVIDER=qwen
# 向量维度固定 1024（两家 embedding 统一对齐；切换 provider 需重建 Milvus collection）
EMBEDDING_DIM=1024

# --- DeepSeek ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- 阿里百炼 DashScope（OpenAI 兼容）---
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_LLM_MODEL=qwen-plus
QWEN_EMB_MODEL=text-embedding-v3

# --- 火山方舟 Ark（OpenAI 兼容；model 字段传 endpoint_id）---
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_LLM_ENDPOINT_ID=
DOUBAO_EMB_MODEL=doubao-embedding-text-240815

# ---------- Milvus（双 collection，向量空间隔离）----------
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=grid_chunks              # 云 embedding(1024维)向量库
MILVUS_COLLECTION_BGE=grid_chunks_bge      # 本地 bge(512维)向量库，独立 collection 向量空间不混

# ---------- Redis（热点问答缓存 + 配置持久化 + query 向量缓存）----------
REDIS_URL=redis://localhost:6379/0
QA_CACHE_TTL=3600

# ---------- Neo4j（知识图谱：设备-故障-处置 多跳推理）----------
# 与 docker-compose 的 NEO4J_AUTH 一致；本机访问用 localhost，容器内用 bolt://neo4j:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123456
KG_RAG_ENABLE=true   # 问答时融合知识图谱结构化上下文(GraphRAG)；关则纯文档检索

# ---------- 重排（rerank）----------
RERANK_ENABLE=true
RERANK_MODEL=gte-rerank-v2

# ---------- 检索质量 ----------
MMR_ENABLE=true            # MMR 多样性重排
MMR_LAMBDA=0.6             # 相关性 vs 多样性 权衡
QUERY_REWRITE_ENABLE=false # LLM 改写 query（增一次 LLM 调用延迟，默认关）
BGE_MODEL=BAAI/bge-small-zh-v1.5   # 可换 bge-large-zh-v1.5(1024维,效果更好)
BGE_DIM=512
DOC_SIZE_THRESHOLD=5000    # 文档总字数超此值 → 走云 embedding；否则本地 bge

# ---------- 分块 ----------
CHUNK_SIZE=500
CHUNK_OVERLAP=80

# ---------- Corrective RAG（检索自纠错闭环）----------
CRAG_ENABLE=true          # 检索后分级+纠错(低相关触发query改写重检索/拒答)
CRAG_HIGH=0.6             # top1 rerank分>=此值=correct(证据充分)
CRAG_LOW=0.3              # top1 rerank分<此值=incorrect(触发纠错)
CRAG_PERDOC_ENABLE=false  # CRAG v2：LLM 逐条评估证据相关性（增延迟，默认关，按需开）

# ---------- 结构感知分块 + Parent-Child（small-to-big）----------
SMALL_TO_BIG_ENABLE=true  # 检索小块、召回同组大块上下文（解决长规程跨块/表格被切）
PARENT_SIZE=2000          # 父块（大块，生成上下文）目标字数
PARENT_OVERLAP=200

# ---------- 检索增强（2026 RAG 趋势，默认关，按需开）----------
HYDE_ENABLE=false         # HyDE：LLM 生成假设答案再做向量检索（短/口语问题提升召回）
MULTI_QUERY_ENABLE=false  # 多查询分解：复杂问题拆子问题并行检索
SELF_RAG_ENABLE=false     # Self-RAG（预留开关）
STANDALONE_REWRITE_ENABLE=true  # 多轮指代消解：追问改写为带上下文独立查询

# ---------- 安全合规（电网强监管）----------
SAFETY_FILTER_ENABLE=true # 入站 prompt injection 告警（计数，不阻断，避免误杀）
PII_MASK_ENABLE=false     # 出站答案敏感信息脱敏（手机/身份证/密码，按合规要求开）
HIGH_RISK_KEYWORDS=停电,拉闸,合闸,接地,挂地线,带电,登高,攀登,放电,倒闸

# ---------- 可信度评测（真 faithfulness，替代粗糙启发式）----------
ONLINE_FAITHFULNESS_ENABLE=true  # 线上答案异步 LLM-judge，前端拉取覆盖"幻觉率"展示
FAITHFULNESS_GATE=0.85           # 生成质量门禁：平均支撑率阈值（scripts/eval_generation.py 用）

# ---------- 多模态 RAG（VLM 图片理解）----------
VLM_ENABLE=false            # VLM 理解图片(图纸/设备/故障现象)补充 OCR 丢失的空间语义
QWEN_VLM_MODEL=qwen-vl-max

# ---------- Self-RAG（检索必要性判断）----------
SELF_RAG_ENABLE=false      # LLM 路由：非运维问题跳过检索直接拒答（省成本+防污染）

# ---------- 配置中心 Nacos（可选，默认 .env）----------
# CONFIG_SOURCE=nacos 时启动从 Nacos 拉取覆盖 .env（docker compose up -d nacos 起服务）
CONFIG_SOURCE=env
NACOS_SERVER=http://localhost:8848
NACOS_NAMESPACE=
NACOS_GROUP=DEFAULT_GROUP
NACOS_DATA_ID=grid-qa.properties

