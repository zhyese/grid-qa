# ===== 复制为 .env 并填入真实值；.env 不会提交到仓库 =====

# ---------- 应用 ----------
APP_NAME=电网运维 RAG 智能问答系统
APP_VERSION=0.1.0
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8001
API_PREFIX=/api
DEBUG=true

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=grid_qa
MYSQL_USER=grid
MYSQL_PASSWORD=grid123456
MYSQL_HOST=localhost
MYSQL_PORT=3307
# 后端连接串（aiomysql 异步驱动；宿主机映射 3307，避开本机已装的 MySQL）
DATABASE_URL=mysql+aiomysql://grid:grid123456@localhost:3307/grid_qa?charset=utf8mb4

# ---------- MinIO ----------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=grid-documents
MINIO_SECURE=false

# ---------- JWT ----------
JWT_SECRET=please-change-this-to-a-random-long-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---------- 默认管理员（首次启动自动创建）----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ---------- 模型 Provider（云 API）----------
# LLM 可切换：deepseek | qwen | doubao
LLM_PROVIDER=deepseek
# Embedding 可切换：qwen | doubao （DeepSeek 无 embedding 接口）
EMB_PROVIDER=qwen
# 向量维度固定 1024（两家 embedding 统一对齐；切换 provider 需重建 Milvus collection）
EMBEDDING_DIM=1024

# --- DeepSeek ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- 阿里百炼 DashScope（OpenAI 兼容）---
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_LLM_MODEL=qwen-plus
QWEN_EMB_MODEL=text-embedding-v3

# --- 火山方舟 Ark（OpenAI 兼容；model 字段传 endpoint_id）---
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_LLM_ENDPOINT_ID=
DOUBAO_EMB_MODEL=doubao-embedding-text-240815

# ---------- Milvus（S5 启用）----------
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=grid_chunks

# ---------- 分块 ----------
CHUNK_SIZE=500
CHUNK_OVERLAP=80
